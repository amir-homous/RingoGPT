# RingoGPT API configuration

# Required:
RINGOGPT_API_KEY=your_api_key_here

# Optional OpenAI-compatible settings:
RINGOGPT_BASE_URL=https://api.openai.com/v1
RINGOGPT_MODEL=gpt-4o-mini

# Optional cache path:
RINGOGPT_CACHE_FILE=~/.ringogpt_cache.json

# Optional command execution timeout in seconds:
RINGOGPT_TIMEOUT=30

# Optional debug flag:
RINGOGPT_DEBUG=false
